      "assertions": [
        {"type": "not_empty", "target": "parsed_html", "message": "WikiText parser must produce output"},
        {"type": "contains", "target": "parsed_html", "value": "wikitext", "message": "Output must use wikitext CSS class"}
      ],
      "metrics": ["parse_time_ms"]
    },
    {
      "id": "yole-fmt-keyvalue-parse",
      "name": "Key-Value Format Parsing",
      "description": "Verify Key-Value parser handles various separators (=, :), comments, sections, multi-line values",
