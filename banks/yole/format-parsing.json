    {
      "id": "yole-fmt-tiddlywiki-parse",
      "name": "TiddlyWiki Format Parsing",
      "description": "Verify TiddlyWiki parser handles tiddler syntax, transclusion, macros, widgets, and formatting",
      "category": "format-parsing",
      "estimated_duration": "20s",
