      ],
      "assertions": [
        {"type": "not_empty", "target": "parsed_html", "message": "Key-Value parser must produce output"},
        {"type": "min_count", "target": "entry_count", "value": 1, "message": "At least one entry expected"}
      ],
      "metrics": ["parse_time_ms", "entry_count"]
    },
    {
      "id": "yole-fmt-taskpaper-parse",
      "name": "TaskPaper Format Parsing",
