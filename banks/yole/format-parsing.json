    },
    {
      "id": "yole-fmt-creole-parse",
      "name": "Creole Wiki Format Parsing",
      "description": "Verify Creole parser handles headings, bold/italic, links, images, lists, tables, and nowiki blocks",
      "category": "format-parsing",
      "estimated_duration": "20s",
      "inputs": [
        {"name": "creole_content", "source": "config", "required": true},
        {"name": "project_root", "source": "env", "required": true}
      ],
      "outputs": [
        {"name": "parsed_html", "type": "string", "description": "HTML rendering of Creole document"},
        {"name": "parse_errors", "type": "json", "description": "Parse errors if any"}
