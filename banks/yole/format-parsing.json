      "name": "Textile Format Parsing",
      "description": "Verify Textile parser handles headings, paragraphs, bold/italic, links, images, lists, and tables",
      "category": "format-parsing",
      "estimated_duration": "20s",
      "inputs": [
        {"name": "textile_content", "source": "config", "required": true},
        {"name": "project_root", "source": "env", "required": true}
      ],
      "outputs": [
