    {
      "id": "yole-fmt-jupyter-parse",
      "name": "Jupyter Notebook Format Parsing",
      "description": "Verify Jupyter parser handles code cells, markdown cells, output cells, metadata, and kernel info",
      "category": "format-parsing",
      "estimated_duration": "30s",
      "inputs": [
        {"name": "jupyter_content", "source": "config", "required": true},
        {"name": "project_root", "source": "env", "required": true}
      ],
      "outputs": [
        {"name": "parsed_html", "type": "string", "description": "HTML rendering of Jupyter notebook"},
        {"name": "cell_count", "type": "string", "description": "Number of cells parsed"},
        {"name": "parse_errors", "type": "json", "description": "Parse errors if any"}
      ],
      "assertions": [
        {"type": "not_empty", "target": "parsed_html", "message": "Jupyter parser must produce output"},
        {"type": "min_count", "target": "cell_count", "value": 1, "message": "At least one cell expected"}
      ],
      "metrics": ["parse_time_ms", "cell_count"]
    },
    {
      "id": "yole-fmt-rmarkdown-parse",
      "name": "R Markdown Format Parsing",
      "description": "Verify R Markdown parser handles YAML front matter, R code chunks, inline R, and Markdown content",
      "category": "format-parsing",
      "dependencies": ["yole-fmt-markdown-basic"],
      "estimated_duration": "30s",
      "inputs": [
        {"name": "rmarkdown_content", "source": "config", "required": true},
        {"name": "project_root", "source": "env", "required": true}
      ],
      "outputs": [
