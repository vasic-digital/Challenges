    {
      "id": "yole-ui-android-share-intent",
      "name": "Android: Share Intent Handling",
      "description": "Send a share intent with text content to the Yole app via ADB. Verify the app opens, receives the shared text, and displays it in the editor.",
      "category": "ui-automation",
      "platform": "android",
      "type": "RecordedMobileFlowChallenge",
      "dependencies": ["yole-ui-android-app-launch"],
      "estimated_duration": "2m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "test_device", "source": "env", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "shared_text", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "adb_broadcast", "target": "device", "value": "am start -a android.intent.action.SEND -t text/plain --es android.intent.extra.TEXT '{{shared_text}}' digital.vasic.yole/.MainActivity"},
        {"action": "wait_for_activity", "target": "device", "value": "MainActivity"},
        {"action": "assert_visible", "target": "editor_area", "value": "true"},
        {"action": "assert_contains", "target": "editor_area", "value": "{{shared_text}}"},
        {"action": "tap", "target": "save_button", "value": ""},
        {"action": "wait", "target": "save_indicator", "value": "saved"}
      ],
      "outputs": [
        {"name": "intent_received", "type": "string", "description": "Whether the share intent was received"},
        {"name": "text_displayed", "type": "string", "description": "Whether shared text appeared in editor"},
        {"name": "content_saveable", "type": "string", "description": "Whether shared content could be saved"}
      ],
      "assertions": [
        {"type": "equals", "target": "intent_received", "value": "true", "message": "Share intent must be received by the app"},
        {"type": "equals", "target": "text_displayed", "value": "true", "message": "Shared text must appear in the editor"},
        {"type": "equals", "target": "content_saveable", "value": "true", "message": "Shared content must be saveable"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["intent_handle_time_ms"]
    },
