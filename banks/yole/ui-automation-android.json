      "outputs": [
        {"name": "fab_expanded", "type": "string", "description": "Whether the FAB menu expanded"},
        {"name": "new_file_created", "type": "string", "description": "Whether new file action worked"},
        {"name": "quick_note_opened", "type": "string", "description": "Whether quick note action worked"}
      ],
      "assertions": [
        {"type": "equals", "target": "fab_expanded", "value": "true", "message": "FAB menu must expand on tap"},
        {"type": "equals", "target": "new_file_created", "value": "true", "message": "New file action must create file and open editor"},
        {"type": "equals", "target": "quick_note_opened", "value": "true", "message": "Quick note action must open QuickNote editor"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["fab_animation_time_ms", "file_create_time_ms"]
