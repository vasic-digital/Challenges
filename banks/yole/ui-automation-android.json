      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "test_device", "source": "env", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "tap", "target": "files_tab", "value": ""},
        {"action": "tap", "target": "fab_button", "value": ""},
        {"action": "assert_visible", "target": "fab_menu", "value": "true"},
        {"action": "tap", "target": "fab_new_file", "value": ""},
        {"action": "assert_visible", "target": "new_file_dialog", "value": "true"},
        {"action": "input_text", "target": "file_name_field", "value": "fab-test.md"},
        {"action": "tap", "target": "dialog_create_button", "value": ""},
        {"action": "assert_visible", "target": "editor_area", "value": "true"},
        {"action": "press_back", "target": "device", "value": ""},
        {"action": "tap", "target": "fab_button", "value": ""},
        {"action": "tap", "target": "fab_quick_note", "value": ""},
        {"action": "assert_visible", "target": "quicknote_editor", "value": "true"}
