{
  "version": "1.0",
  "name": "Yole Android UI Automation Challenges",
  "metadata": {
    "project": "yole",
    "domain": "ui-automation-android",
    "description": "Android app UI automation flows via ADB with recording at three speed modes (slow, normal, fast)"
  },
  "challenges": [
    {
      "id": "yole-ui-android-app-launch",
      "name": "Android: App Launch from Launcher",
      "description": "Launch the Yole Android app from the device launcher, verify the splash screen displays, the main activity starts, and the bottom navigation bar renders within acceptable time bounds at each speed mode.",
      "category": "ui-automation",
      "platform": "android",
      "type": "RecordedMobileLaunchChallenge",
      "dependencies": ["yole-build-android-debug"],
      "estimated_duration": "2m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "apk_path", "source": "dependency:yole-build-android-debug", "required": true},
        {"name": "test_device", "source": "env", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "adb_install", "target": "device", "value": "{{apk_path}}"},
        {"action": "adb_launch", "target": "device", "value": "digital.vasic.yole/.MainActivity"},
        {"action": "wait_for_activity", "target": "device", "value": "MainActivity"},
        {"action": "assert_visible", "target": "bottom_navigation", "value": "true"},
        {"action": "assert_visible", "target": "files_tab", "value": "true"},
        {"action": "assert_visible", "target": "todo_tab", "value": "true"},
        {"action": "assert_visible", "target": "quicknote_tab", "value": "true"},
        {"action": "assert_visible", "target": "more_tab", "value": "true"},
        {"action": "measure", "target": "launch_time_ms", "value": "elapsed"}
      ],
      "outputs": [
        {"name": "app_installed", "type": "string", "description": "Whether the APK was installed"},
        {"name": "app_launched", "type": "string", "description": "Whether the main activity started"},
        {"name": "bottom_nav_rendered", "type": "string", "description": "Whether the bottom navigation rendered"},
        {"name": "launch_time_ms", "type": "string", "description": "Time from intent to interactive"}
      ],
      "assertions": [
        {"type": "equals", "target": "app_installed", "value": "true", "message": "APK must install on device"},
        {"type": "equals", "target": "app_launched", "value": "true", "message": "Main activity must start"},
        {"type": "equals", "target": "bottom_nav_rendered", "value": "true", "message": "Bottom navigation must render with all tabs"},
        {"type": "max_latency", "target": "launch_time_ms", "value": 5000, "message": "App must launch within 5 seconds"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["launch_time_ms", "first_frame_time_ms"]
    },
    {
      "id": "yole-ui-android-bottom-navigation",
      "name": "Android: Bottom Navigation (Files, Todo, QuickNote, More)",
      "description": "Tap each bottom navigation tab in sequence and verify each screen renders its expected content. Verify the selected tab indicator updates.",
      "category": "ui-automation",
      "platform": "android",
      "type": "RecordedMobileFlowChallenge",
      "dependencies": ["yole-ui-android-app-launch"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "test_device", "source": "env", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "tap", "target": "files_tab", "value": ""},
        {"action": "assert_visible", "target": "file_browser_list", "value": "true"},
        {"action": "assert_selected", "target": "files_tab", "value": "true"},
        {"action": "tap", "target": "todo_tab", "value": ""},
        {"action": "assert_visible", "target": "todo_task_list", "value": "true"},
        {"action": "assert_selected", "target": "todo_tab", "value": "true"},
        {"action": "tap", "target": "quicknote_tab", "value": ""},
        {"action": "assert_visible", "target": "quicknote_editor", "value": "true"},
        {"action": "assert_selected", "target": "quicknote_tab", "value": "true"},
        {"action": "tap", "target": "more_tab", "value": ""},
        {"action": "assert_visible", "target": "more_menu", "value": "true"},
        {"action": "assert_selected", "target": "more_tab", "value": "true"},
        {"action": "tap", "target": "files_tab", "value": ""},
        {"action": "assert_visible", "target": "file_browser_list", "value": "true"}
      ],
      "outputs": [
        {"name": "files_tab_works", "type": "string", "description": "Whether Files tab rendered correctly"},
        {"name": "todo_tab_works", "type": "string", "description": "Whether Todo tab rendered correctly"},
        {"name": "quicknote_tab_works", "type": "string", "description": "Whether QuickNote tab rendered correctly"},
        {"name": "more_tab_works", "type": "string", "description": "Whether More tab rendered correctly"},
        {"name": "return_to_files", "type": "string", "description": "Whether returning to Files worked"}
      ],
      "assertions": [
        {"type": "equals", "target": "files_tab_works", "value": "true", "message": "Files tab must render file browser"},
        {"type": "equals", "target": "todo_tab_works", "value": "true", "message": "Todo tab must render task list"},
        {"type": "equals", "target": "quicknote_tab_works", "value": "true", "message": "QuickNote tab must render editor"},
        {"type": "equals", "target": "more_tab_works", "value": "true", "message": "More tab must render menu"},
        {"type": "equals", "target": "return_to_files", "value": "true", "message": "Must return to Files tab cleanly"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["tab_switch_time_ms"]
    },
    {
