    {
      "id": "yole-ui-android-create-document-keyboard",
      "name": "Android: Document Creation with On-Screen Keyboard",
      "description": "Create a new Markdown document and type content using the on-screen keyboard. Verify keyboard appears, text is entered correctly, and the content is saved.",
      "category": "ui-automation",
      "platform": "android",
      "type": "RecordedMobileFlowChallenge",
      "dependencies": ["yole-ui-android-app-launch"],
      "estimated_duration": "4m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "test_device", "source": "env", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "tap", "target": "files_tab", "value": ""},
        {"action": "tap", "target": "fab_button", "value": ""},
        {"action": "tap", "target": "fab_new_file", "value": ""},
        {"action": "input_text", "target": "file_name_field", "value": "mobile-doc.md"},
        {"action": "tap", "target": "dialog_create_button", "value": ""},
        {"action": "tap", "target": "editor_area", "value": ""},
        {"action": "assert_visible", "target": "soft_keyboard", "value": "true"},
        {"action": "input_text", "target": "editor_area", "value": "# Mobile Document\n\nTyped on **Android** with the on-screen keyboard.\n\n- Buy groceries\n- Walk the dog"},
        {"action": "tap", "target": "save_button", "value": ""},
        {"action": "wait", "target": "save_indicator", "value": "saved"},
        {"action": "assert_contains", "target": "editor_area", "value": "# Mobile Document"},
        {"action": "adb_hide_keyboard", "target": "device", "value": ""}
      ],
      "outputs": [
        {"name": "keyboard_shown", "type": "string", "description": "Whether the on-screen keyboard appeared"},
        {"name": "text_entered", "type": "string", "description": "Whether text was entered correctly"},
        {"name": "content_saved", "type": "string", "description": "Whether the content was saved"}
      ],
      "assertions": [
        {"type": "equals", "target": "keyboard_shown", "value": "true", "message": "On-screen keyboard must appear when editor is tapped"},
        {"type": "equals", "target": "text_entered", "value": "true", "message": "Text must be entered correctly via keyboard"},
        {"type": "equals", "target": "content_saved", "value": "true", "message": "Content must be saved to storage"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["keyboard_show_time_ms", "typing_input_time_ms", "save_time_ms"]
    },
    {
      "id": "yole-ui-android-swipe-scroll",
      "name": "Android: Swipe Gestures and Scroll",
      "description": "Open a long document, verify smooth scrolling via swipe gestures. Test fling scrolling, precise scrolling, and scroll-to-top/bottom.",
      "category": "ui-automation",
      "platform": "android",
      "type": "RecordedMobileFlowChallenge",
      "dependencies": ["yole-ui-android-create-document-keyboard"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "test_device", "source": "env", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "long_document", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "open_file", "target": "file_browser", "value": "{{long_document}}"},
        {"action": "wait_for_render", "target": "editor_area", "value": "content_loaded"},
        {"action": "swipe_up", "target": "editor_area", "value": "fast"},
        {"action": "assert_scrolled", "target": "editor_area", "value": "down"},
        {"action": "swipe_up", "target": "editor_area", "value": "slow"},
        {"action": "assert_scrolled", "target": "editor_area", "value": "down"},
        {"action": "swipe_down", "target": "editor_area", "value": "fast"},
        {"action": "assert_scrolled", "target": "editor_area", "value": "up"},
        {"action": "fling", "target": "editor_area", "value": "down"},
        {"action": "wait", "target": "scroll_animation", "value": "complete"},
        {"action": "assert_scrolled", "target": "editor_area", "value": "near_bottom"}
      ],
      "outputs": [
        {"name": "scroll_down_works", "type": "string", "description": "Whether scrolling down worked"},
        {"name": "scroll_up_works", "type": "string", "description": "Whether scrolling up worked"},
        {"name": "fling_works", "type": "string", "description": "Whether fling scrolling worked"},
        {"name": "scroll_smooth", "type": "string", "description": "Whether scrolling was smooth (no jank)"}
      ],
      "assertions": [
        {"type": "equals", "target": "scroll_down_works", "value": "true", "message": "Swipe up must scroll content down"},
        {"type": "equals", "target": "scroll_up_works", "value": "true", "message": "Swipe down must scroll content up"},
        {"type": "equals", "target": "fling_works", "value": "true", "message": "Fling gesture must scroll with momentum"},
        {"type": "equals", "target": "scroll_smooth", "value": "true", "message": "Scrolling must be smooth without jank"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["scroll_fps", "fling_distance_px"]
    },
