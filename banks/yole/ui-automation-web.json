{
  "version": "1.0",
  "name": "Yole Web UI Automation Challenges",
  "metadata": {
    "project": "yole",
    "domain": "ui-automation-web",
    "description": "Web/Wasm PWA UI automation flows via Playwright with recording at three speed modes (slow, normal, fast)"
  },
  "challenges": [
    {
      "id": "yole-ui-web-pwa-launch",
      "name": "Web: PWA Launch in Chrome",
      "description": "Navigate to the Yole Wasm PWA URL in Chrome, verify the Wasm module initializes, the app shell renders, and the main UI becomes interactive within acceptable time bounds at each speed mode.",
      "category": "ui-automation",
      "platform": "web",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-build-web-wasm"],
      "estimated_duration": "2m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "web_app_url", "source": "config", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "navigate", "target": "browser", "value": "{{web_app_url}}"},
        {"action": "wait_for_render", "target": "app_shell", "value": "visible"},
        {"action": "assert_visible", "target": "file_browser_panel", "value": "true"},
        {"action": "assert_visible", "target": "editor_area", "value": "true"},
        {"action": "assert_visible", "target": "toolbar", "value": "true"},
        {"action": "measure", "target": "pwa_load_time_ms", "value": "elapsed"},
        {"action": "evaluate_js", "target": "browser", "value": "document.querySelector('[data-wasm-ready]') !== null"}
      ],
      "outputs": [
        {"name": "pwa_loaded", "type": "string", "description": "Whether the PWA loaded in the browser"},
        {"name": "wasm_initialized", "type": "string", "description": "Whether the Wasm module initialized"},
        {"name": "ui_interactive", "type": "string", "description": "Whether the UI became interactive"},
        {"name": "pwa_load_time_ms", "type": "string", "description": "Time from navigation to interactive"}
      ],
      "assertions": [
        {"type": "equals", "target": "pwa_loaded", "value": "true", "message": "PWA must load in Chrome"},
        {"type": "equals", "target": "wasm_initialized", "value": "true", "message": "Wasm module must initialize"},
        {"type": "equals", "target": "ui_interactive", "value": "true", "message": "UI must become interactive"},
        {"type": "max_latency", "target": "pwa_load_time_ms", "value": 15000, "message": "PWA must load within 15 seconds"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["pwa_load_time_ms", "wasm_init_time_ms", "first_paint_time_ms"]
    },
    {
      "id": "yole-ui-web-file-browser",
      "name": "Web: File Browser Navigation",
      "description": "Navigate the file browser in the Web app: create a folder, enter it, go back, and verify the browser-based IndexedDB storage reflects the folder structure.",
      "category": "ui-automation",
      "platform": "web",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-web-pwa-launch"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "web_app_url", "source": "config", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "folder_name", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "navigate", "target": "browser", "value": "{{web_app_url}}"},
        {"action": "wait_for_render", "target": "app_shell", "value": "visible"},
        {"action": "click", "target": "file_browser_panel", "value": ""},
        {"action": "click", "target": "new_folder_button", "value": ""},
        {"action": "fill", "target": "folder_name_input", "value": "{{folder_name}}"},
        {"action": "press_key", "target": "folder_name_input", "value": "Enter"},
        {"action": "assert_visible", "target": "folder_{{folder_name}}", "value": "true"},
        {"action": "click", "target": "folder_{{folder_name}}", "value": ""},
        {"action": "assert_url_contains", "target": "browser", "value": "{{folder_name}}"},
        {"action": "click", "target": "breadcrumb_parent", "value": ""},
        {"action": "assert_visible", "target": "folder_{{folder_name}}", "value": "true"}
      ],
      "outputs": [
        {"name": "folder_created", "type": "string", "description": "Whether the folder was created in IndexedDB"},
        {"name": "navigation_in", "type": "string", "description": "Whether navigating into the folder worked"},
        {"name": "navigation_out", "type": "string", "description": "Whether navigating back worked"}
      ],
      "assertions": [
        {"type": "equals", "target": "folder_created", "value": "true", "message": "Folder must be created in browser storage"},
        {"type": "equals", "target": "navigation_in", "value": "true", "message": "Must navigate into folder"},
        {"type": "equals", "target": "navigation_out", "value": "true", "message": "Must navigate back to parent"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["folder_create_time_ms", "navigation_time_ms"]
    },
    {
      "id": "yole-ui-web-create-markdown",
      "name": "Web: Create Markdown Document",
      "description": "Create a new Markdown document in the browser, type content with headings, lists, and code blocks. Save to IndexedDB and verify persistence by refreshing the page.",
      "category": "ui-automation",
      "platform": "web",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-web-pwa-launch"],
      "estimated_duration": "4m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "web_app_url", "source": "config", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "file_name", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "navigate", "target": "browser", "value": "{{web_app_url}}"},
        {"action": "wait_for_render", "target": "app_shell", "value": "visible"},
        {"action": "click", "target": "new_file_button", "value": ""},
        {"action": "fill", "target": "file_name_input", "value": "{{file_name}}.md"},
        {"action": "press_key", "target": "file_name_input", "value": "Enter"},
        {"action": "fill", "target": "editor_area", "value": "# Web Document\n\nCreated in the **Wasm PWA**.\n\n- Task one\n- Task two\n\n```js\nconsole.log('Hello from Yole Web!');\n```"},
        {"action": "click", "target": "save_button", "value": ""},
        {"action": "wait", "target": "save_indicator", "value": "saved"},
        {"action": "navigate", "target": "browser", "value": "{{web_app_url}}"},
        {"action": "wait_for_render", "target": "app_shell", "value": "visible"},
        {"action": "click", "target": "file_{{file_name}}.md", "value": ""},
        {"action": "assert_contains", "target": "editor_area", "value": "# Web Document"}
      ],
      "outputs": [
        {"name": "file_created", "type": "string", "description": "Whether the file was created"},
        {"name": "content_saved", "type": "string", "description": "Whether content was saved to IndexedDB"},
        {"name": "content_persisted", "type": "string", "description": "Whether content survived page refresh"}
      ],
      "assertions": [
        {"type": "equals", "target": "file_created", "value": "true", "message": "File must be created in browser"},
        {"type": "equals", "target": "content_saved", "value": "true", "message": "Content must be saved to IndexedDB"},
        {"type": "equals", "target": "content_persisted", "value": "true", "message": "Content must persist after page refresh"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["file_create_time_ms", "save_time_ms", "reload_time_ms"]
    },
    {
      "id": "yole-ui-web-create-todotxt",
