        {"action": "wait_for_render", "target": "editor_area", "value": "content_loaded"},
        {"action": "click", "target": "editor_area", "value": ""},
        {"action": "press_key", "target": "editor_area", "value": "End"},
        {"action": "press_key", "target": "editor_area", "value": "Enter"},
        {"action": "fill", "target": "editor_area_cursor", "value": "\n## Added by Web Automation\n\nThis section was appended by the Playwright test."},
        {"action": "click", "target": "save_button", "value": ""},
        {"action": "wait", "target": "save_indicator", "value": "saved"},
        {"action": "assert_contains", "target": "editor_area", "value": "Added by Web Automation"}
      ],
      "outputs": [
