        {"name": "content_modified", "type": "string", "description": "Whether content was modified"},
        {"name": "changes_saved", "type": "string", "description": "Whether changes were saved"}
      ],
      "assertions": [
        {"type": "equals", "target": "file_opened", "value": "true", "message": "File must open in editor"},
        {"type": "equals", "target": "content_modified", "value": "true", "message": "Content must be editable"},
        {"type": "equals", "target": "changes_saved", "value": "true", "message": "Changes must persist in IndexedDB"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["file_open_time_ms", "save_time_ms"]
    },
