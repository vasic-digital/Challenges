    {
      "id": "yole-ui-web-edit-document",
      "name": "Web: Edit Existing Document",
      "description": "Open an existing document in the Web app, modify content, save, and verify modifications are reflected in IndexedDB storage.",
      "category": "ui-automation",
      "platform": "web",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-web-create-markdown"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "web_app_url", "source": "config", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "test_file", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "navigate", "target": "browser", "value": "{{web_app_url}}"},
        {"action": "wait_for_render", "target": "app_shell", "value": "visible"},
