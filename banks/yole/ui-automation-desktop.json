{
  "version": "1.0",
  "name": "Yole Desktop UI Automation Challenges",
  "metadata": {
    "project": "yole",
    "domain": "ui-automation-desktop",
    "description": "Desktop Compose app UI automation flows with recording at three speed modes (slow, normal, fast)"
  },
  "challenges": [
    {
      "id": "yole-ui-desktop-cold-start",
      "name": "Desktop: App Cold Start and Initial Render",
      "description": "Launch the Compose Desktop app from a cold state, verify the main window renders with the file browser panel, editor area, and toolbar within acceptable time bounds at each speed mode.",
      "category": "ui-automation",
      "platform": "desktop",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-build-desktop-jar"],
      "estimated_duration": "2m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "jar_path", "source": "dependency:yole-build-desktop-jar", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "launch", "target": "desktopApp", "value": "jar_path"},
        {"action": "wait_for_render", "target": "main_window", "value": "visible"},
        {"action": "assert_visible", "target": "file_browser_panel", "value": "true"},
        {"action": "assert_visible", "target": "editor_area", "value": "true"},
        {"action": "assert_visible", "target": "toolbar", "value": "true"},
        {"action": "measure", "target": "cold_start_time_ms", "value": "elapsed"}
      ],
      "outputs": [
        {"name": "app_launched", "type": "string", "description": "Whether the app window appeared"},
        {"name": "main_window_rendered", "type": "string", "description": "Whether all main UI panels rendered"},
        {"name": "cold_start_time_ms", "type": "string", "description": "Time from launch to full render"}
      ],
      "assertions": [
        {"type": "equals", "target": "app_launched", "value": "true", "message": "Desktop app must launch successfully"},
        {"type": "equals", "target": "main_window_rendered", "value": "true", "message": "Main window must render all panels"},
        {"type": "max_latency", "target": "cold_start_time_ms", "value": 8000, "message": "Cold start must complete within 8 seconds"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["cold_start_time_ms", "window_render_time_ms"]
    },
    {
      "id": "yole-ui-desktop-file-browser-navigation",
      "name": "Desktop: File Browser Navigation",
      "description": "Create a new folder in the file browser, navigate into it, navigate back out, and verify the breadcrumb trail and folder listing update correctly at each speed mode.",
      "category": "ui-automation",
      "platform": "desktop",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-desktop-cold-start"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "jar_path", "source": "dependency:yole-build-desktop-jar", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "folder_name", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "click", "target": "file_browser_panel", "value": ""},
        {"action": "right_click", "target": "file_browser_panel", "value": "context_menu"},
        {"action": "click", "target": "context_menu_new_folder", "value": ""},
        {"action": "type", "target": "folder_name_input", "value": "{{folder_name}}"},
        {"action": "press_key", "target": "folder_name_input", "value": "Enter"},
        {"action": "assert_visible", "target": "folder_{{folder_name}}", "value": "true"},
        {"action": "double_click", "target": "folder_{{folder_name}}", "value": ""},
        {"action": "assert_text", "target": "breadcrumb_trail", "value": "{{folder_name}}"},
        {"action": "click", "target": "breadcrumb_parent", "value": ""},
        {"action": "assert_visible", "target": "folder_{{folder_name}}", "value": "true"}
      ],
      "outputs": [
        {"name": "folder_created", "type": "string", "description": "Whether the new folder appeared in the listing"},
        {"name": "navigation_in", "type": "string", "description": "Whether navigating into the folder succeeded"},
        {"name": "navigation_out", "type": "string", "description": "Whether navigating back to parent succeeded"}
      ],
      "assertions": [
        {"type": "equals", "target": "folder_created", "value": "true", "message": "New folder must appear in file browser"},
        {"type": "equals", "target": "navigation_in", "value": "true", "message": "Must navigate into folder and update breadcrumb"},
        {"type": "equals", "target": "navigation_out", "value": "true", "message": "Must navigate back to parent directory"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["folder_create_time_ms", "navigation_time_ms"]
    },
    {
      "id": "yole-ui-desktop-create-markdown",
      "name": "Desktop: Create Markdown Document",
      "description": "Create a new Markdown document, type real content including headings, bold text, a list, and a code block. Save the file and verify the content persists across a reload.",
      "category": "ui-automation",
      "platform": "desktop",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-desktop-cold-start"],
      "estimated_duration": "4m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "jar_path", "source": "dependency:yole-build-desktop-jar", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "file_name", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "keyboard_shortcut", "target": "Ctrl+N", "value": "new_file"},
        {"action": "type", "target": "file_name_dialog", "value": "{{file_name}}.md"},
        {"action": "press_key", "target": "file_name_dialog", "value": "Enter"},
        {"action": "type", "target": "editor_area", "value": "# Test Document\n\nThis is a **bold** test.\n\n- Item one\n- Item two\n- Item three\n\n```kotlin\nfun main() {\n    println(\"Hello, Yole!\")\n}\n```"},
        {"action": "keyboard_shortcut", "target": "Ctrl+S", "value": "save"},
        {"action": "wait", "target": "save_indicator", "value": "saved"},
        {"action": "close_tab", "target": "editor_tab", "value": ""},
        {"action": "open_file", "target": "file_browser", "value": "{{file_name}}.md"},
        {"action": "assert_contains", "target": "editor_area", "value": "# Test Document"}
      ],
      "outputs": [
        {"name": "file_created", "type": "string", "description": "Whether the new Markdown file was created"},
        {"name": "content_saved", "type": "string", "description": "Whether the content was saved successfully"},
        {"name": "content_persisted", "type": "string", "description": "Whether content survived close and reopen"}
      ],
      "assertions": [
        {"type": "equals", "target": "file_created", "value": "true", "message": "New Markdown file must be created"},
        {"type": "equals", "target": "content_saved", "value": "true", "message": "Content must be saved to disk"},
        {"type": "equals", "target": "content_persisted", "value": "true", "message": "Content must persist after close and reopen"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["file_create_time_ms", "save_time_ms", "reopen_time_ms"]
    },
    {
      "id": "yole-ui-desktop-create-todotxt",
      "name": "Desktop: Create Todo.txt Document",
      "description": "Create a new todo.txt file, enter tasks with priorities, projects, and contexts. Verify task parsing, priority highlighting, and sort order.",
      "category": "ui-automation",
      "platform": "desktop",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-desktop-cold-start"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "jar_path", "source": "dependency:yole-build-desktop-jar", "required": true},
        {"name": "speed_mode", "source": "config", "required": true}
      ],
      "steps": [
        {"action": "keyboard_shortcut", "target": "Ctrl+N", "value": "new_file"},
        {"action": "type", "target": "file_name_dialog", "value": "tasks.todo"},
        {"action": "press_key", "target": "file_name_dialog", "value": "Enter"},
        {"action": "type", "target": "editor_area", "value": "(A) Write UI automation tests +yole @dev due:2026-03-20\n(B) Review pull request +yole @review\n(C) Update documentation +yole @docs\nx 2026-03-15 Complete challenge banks +yole @dev"},
        {"action": "keyboard_shortcut", "target": "Ctrl+S", "value": "save"},
        {"action": "assert_visible", "target": "priority_highlight_A", "value": "true"},
        {"action": "assert_visible", "target": "project_tag_yole", "value": "true"},
        {"action": "assert_visible", "target": "context_tag_dev", "value": "true"},
        {"action": "assert_visible", "target": "completed_task_indicator", "value": "true"}
      ],
      "outputs": [
        {"name": "file_created", "type": "string", "description": "Whether the todo.txt file was created"},
        {"name": "tasks_parsed", "type": "string", "description": "Whether tasks were parsed with priorities and tags"},
        {"name": "completion_tracked", "type": "string", "description": "Whether completed task was marked correctly"}
      ],
      "assertions": [
        {"type": "equals", "target": "file_created", "value": "true", "message": "Todo.txt file must be created"},
        {"type": "equals", "target": "tasks_parsed", "value": "true", "message": "Tasks must be parsed with priorities, projects, and contexts"},
        {"type": "equals", "target": "completion_tracked", "value": "true", "message": "Completed task must show completion indicator"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["file_create_time_ms", "parse_time_ms"]
    },
    {
      "id": "yole-ui-desktop-edit-existing",
      "name": "Desktop: Edit Existing Document",
      "description": "Open an existing document from the file browser, modify content by adding and removing lines, save changes, and verify modifications persist.",
      "category": "ui-automation",
      "platform": "desktop",
      "type": "RecordedBrowserFlowChallenge",
      "dependencies": ["yole-ui-desktop-create-markdown"],
      "estimated_duration": "3m",
      "speed_modes": ["slow", "normal", "fast"],
      "inputs": [
        {"name": "jar_path", "source": "dependency:yole-build-desktop-jar", "required": true},
        {"name": "speed_mode", "source": "config", "required": true},
        {"name": "test_file", "source": "config", "required": true}
      ],
      "steps": [
