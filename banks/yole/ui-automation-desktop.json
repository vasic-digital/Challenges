        {"action": "wait_for_render", "target": "editor_area", "value": "content_loaded"},
        {"action": "click", "target": "editor_line_3", "value": ""},
        {"action": "select_all_line", "target": "editor_line_3", "value": ""},
        {"action": "type", "target": "editor_area", "value": "This line was modified by the automation test."},
        {"action": "press_key", "target": "editor_area", "value": "Enter"},
        {"action": "type", "target": "editor_area", "value": "This is a newly inserted line."},
        {"action": "keyboard_shortcut", "target": "Ctrl+S", "value": "save"},
        {"action": "wait", "target": "save_indicator", "value": "saved"},
        {"action": "assert_contains", "target": "editor_area", "value": "modified by the automation test"}
      ],
      "outputs": [
        {"name": "file_opened", "type": "string", "description": "Whether the file opened in the editor"},
        {"name": "content_modified", "type": "string", "description": "Whether content was successfully modified"},
        {"name": "changes_saved", "type": "string", "description": "Whether changes were saved to disk"}
      ],
      "assertions": [
        {"type": "equals", "target": "file_opened", "value": "true", "message": "Existing file must open in the editor"},
        {"type": "equals", "target": "content_modified", "value": "true", "message": "Content must be editable"},
        {"type": "equals", "target": "changes_saved", "value": "true", "message": "Changes must persist after save"}
      ],
      "recording": {"enabled": true, "validate": true},
      "metrics": ["file_open_time_ms", "save_time_ms"]
    },
    {
